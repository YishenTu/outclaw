{
	"name": "outclaw",
	"description": "A mini OpenClaw — autonomous AI agent with Claude Agent SDK backend, TUI and Telegram frontends, and a runtime orchestrator",
	"module": "src/index.ts",
	"type": "module",
	"private": true,
	"bin": {
		"oc": "src/cli.ts"
	},
	"scripts": {
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage",
		"check:coverage": "bun run scripts/check-coverage.ts",
		"check:boundaries": "bun run scripts/check-boundaries.ts",
		"check": "bun run lint && bun run typecheck && bun run check:boundaries && bun run test"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/bun": "latest",
		"@types/figlet": "^1.7.0",
		"@types/marked-terminal": "^6.1.1",
		"@types/react": "^19.2.14"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.92",
		"@grammyjs/auto-retry": "^2.0.2",
		"chalk": "^5.6.2",
		"croner": "^10.0.1",
		"figlet": "^1.11.0",
		"grammy": "^1.42.0",
		"ink": "^6.8.0",
		"ink-multiline-input": "^0.1.0",
		"marked": "15",
		"marked-terminal": "^7.3.0",
		"react": "^19.2.4",
		"yaml": "^2.8.3"
	}
}
