{
	"name": "misanthropic",
	"description": "A mini OpenClaw — autonomous AI agent with Claude Agent SDK backend, optional browser/TUI frontend, and a runtime orchestrator",
	"module": "src/index.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"check": "bun run lint && bun run typecheck && bun run test",
		"start": "bun src/index.ts",
		"tui": "bun src/tui.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/bun": "latest",
		"@types/react": "^19.2.14"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.92",
		"grammy": "^1.42.0",
		"hono": "^4.12.11",
		"ink": "^6.8.0",
		"ink-text-input": "^6.0.0",
		"react": "^19.2.4",
		"zod": "^4.3.6"
	}
}
