{
	"name": "misanthropic",
	"description": "A mini OpenClaw — autonomous AI agent with Claude Agent SDK backend, optional browser/TUI frontend, and a runtime orchestrator",
	"module": "src/index.ts",
	"type": "module",
	"private": true,
	"bin": {
		"ma": "src/cli.ts"
	},
	"scripts": {
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"check": "bun run lint && bun run typecheck && bun run test"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/bun": "latest",
		"@types/react": "^19.2.14"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.92",
		"@grammyjs/auto-retry": "^2.0.2",
		"@grammyjs/stream": "^1.0.1",
		"croner": "^10.0.1",
		"grammy": "^1.42.0",
		"ink": "^6.8.0",
		"ink-text-input": "^6.0.0",
		"react": "^19.2.4",
		"yaml": "^2.8.3"
	}
}
