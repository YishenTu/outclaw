# Per-agent Telegram config
# Each agent uses the folder selector name to derive env placeholders.
# Multiple user IDs are comma-separated.
# Agents may share the same bot token.

RAILLY_TELEGRAM_BOT_TOKEN=your-bot-token-here
RAILLY_TELEGRAM_USERS=762901060

MIMI_TELEGRAM_BOT_TOKEN=your-bot-token-here
MIMI_TELEGRAM_USERS=123456789,987654321
